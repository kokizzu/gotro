    "build:prod": "node build.js --minify",
    "serve": "node build.js --serve"
  },
  "devDependencies": {
    "chokidar": "^3.6.0",
    "esbuild": "^0.27.4",
    "esbuild-svelte": "^0.9.4",
    "five-server": "^0.4.1",
